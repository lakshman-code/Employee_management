generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("EMPLOYEE") // Can be "EMPLOYEE" or "HR"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
